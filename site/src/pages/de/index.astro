---
import BaseLayout from '@/layouts/BaseLayout.astro';
import TopicCard from '@/components/TopicCard.astro';
import SearchBar from '@/components/SearchBar.astro';
import RecentUpdates from '@/components/RecentUpdates.astro';
import { getAllTopics } from '@/lib/content';
import { t } from '@/lib/i18n';

const lang = 'de';
const topics = getAllTopics();
---

<BaseLayout lang={lang}>
  <section class="hero">
    <h1>{t('site.title', lang)}</h1>
    <p class="hero-subtitle">{t('site.subtitle', lang)}</p>
  </section>

  <SearchBar lang={lang} />

  <RecentUpdates lang={lang} />

  <section class="topics-section">
    <h2>{t('home.topics', lang)}</h2>
    <div class="topics-grid">
      {topics.map((topic) => (
        <TopicCard meta={topic.meta} lang={lang} />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: var(--spacing-2xl) 0 var(--spacing-xl);
  }

  .hero h1 {
    font-size: 2.8rem;
    letter-spacing: -0.03em;
  }

  .hero-subtitle {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-style: italic;
    color: var(--color-text-secondary);
    margin-top: var(--spacing-sm);
  }

  .topics-section h2 {
    font-size: 1.3rem;
    margin-bottom: var(--spacing-lg);
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--spacing-lg);
  }
</style>
